# EduVideo environment example
# Copy this file to your real environment settings.
# Do NOT commit real secrets to GitHub.

# Frontend public config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Server-only secrets. Use only in backend/edge functions, never in browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PAYMENT_WEBHOOK_SECRET=your-payment-webhook-secret
VIDEO_SIGNING_SECRET=your-video-signing-secret

# App URLs
PUBLIC_SITE_URL=https://tuvungonline-gif.github.io/hoctructuyen/
AUTH_REDIRECT_URL=https://tuvungonline-gif.github.io/hoctructuyen/#/auth-callback

# Optional providers
PAYMENT_PROVIDER=your-provider
VIDEO_PROVIDER=your-video-provider
